# ==============================================================================
# PMS Dashboard - DevOps Environment Configuration Template
# ==============================================================================

# Backend Configuration
APP_ENV=production
DATABASE_URL=postgresql://postgres:<password>@db:5432/PMS_Sys
PMS_AUTO_SEED=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_RECYCLE=1800
REDIS_URL=redis://:<password>@redis:6379/0
JWT_SECRET=<replace-with-a-32-byte-random-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=https://pms-eta-rust.vercel.app,https://pms-egzjdxcfx-zain-mustafas-projects.vercel.app,http://localhost:5173,http://localhost:3000
MAX_UPLOAD_BYTES=26214400
FRONTEND_URL=https://pms-eta-rust.vercel.app

# Frontend Configuration
VITE_API_BASE_URL=https://pms-backend-six.vercel.app
VITE_SOCKET_URL=http://localhost:8000

# PostgreSQL Container Configuration
POSTGRES_DB=PMS_Sys
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<replace-with-a-strong-password>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Container Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<replace-with-a-strong-url-safe-password>

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<replace-with-a-strong-password>

# Deployment Metadata
ENVIRONMENT=production
APP_VERSION=2.0.0
